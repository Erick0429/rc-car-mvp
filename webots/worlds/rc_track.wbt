#VRML_SIM R2023b utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/vehicles/protos/vehicle/Car.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/vehicles/protos/vehicle/VehicleWheel.proto"

WorldInfo {
  info [
    "RC Car Autonomous Driving Simulation"
    "Track: simple oval"
  ]
  title "RC Car Sim"
  basicTimeStep 32
  coordinateSystem "NUE"
}

Viewpoint {
  orientation -0.5773502691896258 0.5773502691896258 0.5773502691896258 2.0944
  position 0 8 0
}

TexturedBackground {
}

TexturedBackgroundLight {
}

# 트랙 바닥
RectangleArena {
  translation 0 0 0
  floorSize 10 6
  floorTileSize 1 1
  wallHeight 0.3
}

# 트랙 가이드 벽 (내부)
DEF INNER_WALL Solid {
  translation 0 0.15 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 1 0
      }
      geometry Box {
        size 6 0.3 3
      }
    }
  ]
  boundingObject Box {
    size 6 0.3 3
  }
}

# RC카 (간단한 박스 모델)
DEF RC_CAR Robot {
  translation 0 0.05 -2
  rotation 0 1 0 0
  children [
    # 차체
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.4 0.8
      }
      geometry Box {
        size 0.3 0.1 0.5
      }
    }
    # 전방 카메라
    Camera {
      translation 0 0.08 -0.2
      rotation 1 0 0 -0.2
      name "camera"
      width 640
      height 480
      near 0.05
      far 20
    }
    # 구동 모터 (후륜)
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 1 0 0
        anchor -0.12 -0.04 0.18
      }
      device [
        RotationalMotor {
          name "left_rear_motor"
          maxVelocity 20
          maxTorque 10
        }
      ]
      endPoint Solid {
        translation -0.12 -0.04 0.18
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { radius 0.04 height 0.03 }
          }
        ]
        boundingObject Cylinder { radius 0.04 height 0.03 }
        physics Physics { density 500 }
      }
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 1 0 0
        anchor 0.12 -0.04 0.18
      }
      device [
        RotationalMotor {
          name "right_rear_motor"
          maxVelocity 20
          maxTorque 10
        }
      ]
      endPoint Solid {
        translation 0.12 -0.04 0.18
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { radius 0.04 height 0.03 }
          }
        ]
        boundingObject Cylinder { radius 0.04 height 0.03 }
        physics Physics { density 500 }
      }
    }
    # 조향 (전륜)
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor -0.12 -0.04 -0.18
      }
      device [
        RotationalMotor {
          name "left_steer"
          minPosition -0.6
          maxPosition 0.6
        }
      ]
      endPoint Solid {
        translation -0.12 -0.04 -0.18
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { radius 0.04 height 0.03 }
          }
        ]
        boundingObject Cylinder { radius 0.04 height 0.03 }
        physics Physics { density 500 }
      }
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0.12 -0.04 -0.18
      }
      device [
        RotationalMotor {
          name "right_steer"
          minPosition -0.6
          maxPosition 0.6
        }
      ]
      endPoint Solid {
        translation 0.12 -0.04 -0.18
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { radius 0.04 height 0.03 }
          }
        ]
        boundingObject Cylinder { radius 0.04 height 0.03 }
        physics Physics { density 500 }
      }
    }
  ]
  boundingObject Box {
    size 0.3 0.1 0.5
  }
  physics Physics {
    density 800
  }
  controller "data_collector"
}
